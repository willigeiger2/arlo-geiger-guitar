---
interface Props {
	heading: string;
}

const { heading } = Astro.props;
---

<div>
    <h2>{heading}</h2>
    <div class="horizontal-grid">
        <slot />
    </div>
</div>
<style>
	.horizontal-grid {
        display: flex;
        gap: 1rem;
        flex-direction: row;
        flex-wrap: nowrap;
        overflow-x: auto;
    }	
	h2 {
	    font-family: "EB Garamond", Garamond, serif;
        font-size: clamp(1.5rem, 4vw, 6rem);
		font-weight: normal;
	}
</style>
