		<VideoCard
			src="https://customer-78c7ewhahv4gi16q.cloudflarestream.com/b1e424f7987c689f9e8befe7bcc98ed7/iframe?poster=https%3A%2F%2Fcustomer-78c7ewhahv4gi16q.cloudflarestream.com%2Fb1e424f7987c689f9e8befe7bcc98ed7%2Fthumbnails%2Fthumbnail.jpg%3Ftime%3D%26height%3D600",
