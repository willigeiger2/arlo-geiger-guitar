	<Heading heading="Awards, public performances, etc."></Heading>
	<HtmlCard htmlContent="\
		<li style='font-size: clamp(1rem, 2vw, 2rem);'>2025: Virtual Guitar Orchestra – <i>After JSB</i>.</li>\
		<li style='font-size: clamp(1rem, 2vw, 2rem);'>2025: SFCM Chamber Music Award.</li>\
		<li style='font-size: clamp(1rem, 2vw, 2rem);'>2025: Opened for Manuel Barrueco at the Herbst Theater, SF.</li>\
		<li style='font-size: clamp(1rem, 2vw, 2rem);'>2024: Attended Aaron Shearer Foundation Summer Institute with Andrew York.</li>\
		<li style='font-size: clamp(1rem, 2vw, 2rem);'>2024: GLORY International Music Competition, 3rd Prize.</li>\
		<li style='font-size: clamp(1rem, 2vw, 2rem);'>2024: Virtual guitar orchestra – <i>Pacific Coast Highway</i>.</li>\
		<li style='font-size: clamp(1rem, 2vw, 2rem);'>2024: Concert at St Mark's, SF – <i>Bluezillian</i>.</li>\
		<li style='font-size: clamp(1rem, 2vw, 2rem);'>2023: Performance at the South Bay Guitar Society Festival.</li>\
		<li style='font-size: clamp(1rem, 2vw, 2rem);'>2023: Virtual guitar orchestra – <i>Mbira</i>.</li>\
		<li style='font-size: clamp(1rem, 2vw, 2rem);'>2022: SFCM Chamber Music Award.</li>"
	></HtmlCard>
</Layout>
